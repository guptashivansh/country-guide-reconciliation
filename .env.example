GROQ_API_KEY=
EXTRACTION_CHUNK_SIZE=6000

# Ollama (local, no rate limits — used for reconciliation if available)
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OFFICIAL_SOURCES_JSON_URL=https://raw.githubusercontent.com/guptashivansh/compliance-data/main/data/official-sources.json

# Database — PostgreSQL is the default.
# Set DATABASE_URL to your connection string. If unset, defaults to postgresql://localhost/country_guides
DATABASE_URL=postgresql://localhost/country_guides

# To use SQLite instead (dev only), uncomment:
# DATABASE_BACKEND=sqlite
# COUNTRY_GUIDE_DB=country_guides.db
